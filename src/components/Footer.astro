---
import Section from './Section.astro'
---
<Section dark={true}>
  <footer>
    <div class="icons-container">
      <a href="/"><img src="/images/icons/email.png" alt="Email icon"/></a>
      <a href="https://github.com/skylanche" target="_blank" rel="me noopener"><img src="/images/icons/github.png" alt="Github icon"/></a>
      <a href="https://linkedin.com/in/sakthi-vignesh-kumar-324ab9144" target="_blank" rel="me noopener"><img src="/images/icons/linkedin.png" alt="LinkedIn icon"/></a>
        
    </div>
    <p class="rights-text">Copyright © 2026 All rights reserved</p>
  </footer>
</Section>

<style>
    footer {
        display: flex;
        align-items: center;
        flex-direction: column;
        

        img{
            width: 50px;
        }

        .icons-container {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            align-items: center;
        }

        .credit-text{
            color: var(--light);
            margin-top: 8px;
            font-size: 14px
        }

        @media screen and (max-width: 500px) {

            .icons-container {
                flex-direction: row;
                gap: 10px;
                img {
                    height: 50px;
                }
            }
            
        }
    }
</style>